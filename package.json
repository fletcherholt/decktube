{
    "name": "decktube",
    "version": "1.0.1",
    "description": "YouTube for TV, tuned for the Steam Deck",
    "main": "src/index.js",
    "scripts": {
        "start": "electron .",
        "windows:build": "electron-builder --win",
        "mac:build": "electron-builder --mac",
        "linux:build": "electron-builder --linux",
        "linux:build-unpacked": "electron-builder --linux --dir",
        "linux:build-appimage": "electron-builder --linux appimage"
    },
    "keywords": [],
    "author": "Fletcher Holt",
    "license": "MIT",
    "build": {
        "appId": "io.github.fletcherholt.DeckTube",
        "productName": "DeckTube",
        "artifactName": "DeckTube-${arch}.${ext}",
        "linux": {
            "icon": "./assets/icon.svg",
            "synopsis": "Watch and explore videos on YouTube",
            "category": "AudioVideo",
            "desktop": {
                "entry": {
                    "Name": "DeckTube",
                    "Type": "Application",
                    "Categories": "AudioVideo;",
                    "Keywords": "YouTube;YT;Deck;"
                }
            },
            "maintainer": "fletcherholt649@gmail.com",
            "target": [
                {
                    "target": "deb",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                },
                {
                    "target": "tar.gz",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                },
                {
                    "target": "AppImage",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                }
            ]
        },
        "win": {
            "icon": "./assets/icon.ico",
            "artifactName": "DeckTube-${arch}-Portable.zip",
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                },
                {
                    "target": "zip",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                }
            ]
        },
        "nsis": {
            "artifactName": "DeckTube-Setup.${ext}",
            "uninstallDisplayName": "DeckTube",
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "allowElevation": true,
            "perMachine": false
        },
        "mac": {
            "icon": "./assets/icon.icns",
            "category": "public.app-category.video",
            "entitlements": "build/entitlements.mac.plist",
            "entitlementsInherit": "build/entitlements.mac.inherit.plist",
            "extendInfo": {
                "NSMicrophoneUsageDescription": "VacuumTube uses the microphone only when you use YouTube voice search."
            },
            "target": [
                {
                    "target": "dmg",
                    "arch": [
                        "universal"
                    ]
                },
                {
                    "target": "zip",
                    "arch": [
                        "universal"
                    ]
                }
            ]
        },
        "publish": {
            "provider": "github",
            "owner": "fletcherholt",
            "repo": "decktube"
        }
    },
    "devDependencies": {
        "electron": "^42.4.1",
        "electron-builder": "^26.0.12"
    },
    "dependencies": {
        "chokidar": "^5.0.0",
        "electron-updater": "^6.8.3",
        "minimist": "^1.2.8",
        "sponsorblock-api": "^0.2.4",
        "string-argv": "^0.3.2",
        "tseep": "^1.3.1"
    }
}
